# MilCalc — environment variables
#
# Copy this file to `.env.local` (which is git-ignored) and fill in real values.
# All variables MUST start with VITE_ to be exposed to the browser by Vite.
# After editing, restart `npm run dev` so Vite picks up the new values.

# ─── Public deployment URL ─────────────────────────────────────────────────
# Required for canonical/OG meta tags, share links, and PDF footer text.
# Use the full origin (with scheme), no trailing slash.
VITE_PUBLIC_URL=https://example.com

# Bare domain shown in PDF footers and share text (no scheme).
VITE_PUBLIC_DOMAIN=example.com

# ─── Support contact ───────────────────────────────────────────────────────
# Email surfaced in FAQ, Terms, Partners page, support modal, and review CTA.
VITE_SUPPORT_EMAIL=support@example.com

# ─── Parent brand / cross-promo ────────────────────────────────────────────
# Optional. URL and bare domain for the "Part of <brand>" footer links and
# the post-export career-tool cross-promo modal. Leave at defaults if you
# have no parent brand — the links will point at example.com.
VITE_PARENT_BRAND_URL=https://example.com
VITE_PARENT_BRAND_DOMAIN=example.com

# ─── Analytics (optional) ──────────────────────────────────────────────────
# Mixpanel project token. Leave blank to disable analytics entirely.
# Find it in: Mixpanel → Project Settings → Access Keys → Project Token.
# Note: client-side tokens are visible to anyone who loads the page — that
# is expected for Mixpanel browser SDKs. Do NOT put a service/secret key here.
VITE_MIXPANEL_TOKEN=
